FUNDCAT_DB_URL=mysql+pymysql://fundcat:change-me-app-password@127.0.0.1:3306/fundcat?charset=utf8mb4
FUNDCAT_OPS_BASE_URL=http://127.0.0.1:8080/api/v1/ops
FUNDCAT_PUBLISH_MODE=log
FUNDCAT_OUTBOX_BATCH_SIZE=200
FUNDCAT_PENDING_QUERY_LIMIT=500

# 当需要切换到真实 RocketMQ 时，把 publish mode 改成 rocketmq。
